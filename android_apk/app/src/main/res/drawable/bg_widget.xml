<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle outer glow / shadow -->
    <item android:top="3dp" android:left="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#33000000"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Thin highlight border (top-left) -->
    <item android:bottom="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#2C2C32"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>
    <!-- Main background with gradient -->
    <item android:bottom="4dp" android:right="4dp" android:top="1dp" android:left="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#1C1C20"
                android:endColor="#111113"
                android:angle="135"/>
            <corners android:radius="17dp"/>
        </shape>
    </item>
</layer-list>
