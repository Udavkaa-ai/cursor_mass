<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:left="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#44000000"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>
    <!-- Glass body: dark semi-transparent -->
    <item android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#C813151C"
                android:endColor="#E00C0D13"
                android:angle="150"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Glass sheen: white top reflection -->
    <item android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#28FFFFFF"
                android:endColor="#03FFFFFF"
                android:angle="90"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Glass border: thin white edge -->
    <item android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/>
            <stroke android:width="1dp" android:color="#35FFFFFF"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</layer-list>
