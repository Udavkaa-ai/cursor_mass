<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Header: location icon + stop name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍"
            android:textSize="14sp"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/tw_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.07"
            android:textColor="#9090B8"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tw_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="9sp"
            android:textColor="#7878A0"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <!-- Arrivals list -->
    <LinearLayout
        android:id="@+id/rows_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Row 1 -->
        <LinearLayout
            android:id="@+id/row1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/r1_route"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="#F4F4F6"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/r1_dir"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="9sp"
                android:textColor="#9090B8"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/r1_eta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9090B8"
                android:layout_marginStart="8dp"
                android:minWidth="30dp"
                android:textAlignment="textEnd"/>

        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:id="@+id/row2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/r2_route"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="#F4F4F6"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/r2_dir"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="9sp"
                android:textColor="#9090B8"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/r2_eta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9090B8"
                android:layout_marginStart="8dp"
                android:minWidth="30dp"
                android:textAlignment="textEnd"/>

        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:id="@+id/row3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/r3_route"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="#F4F4F6"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/r3_dir"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="9sp"
                android:textColor="#9090B8"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/r3_eta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9090B8"
                android:layout_marginStart="8dp"
                android:minWidth="30dp"
                android:textAlignment="textEnd"/>

        </LinearLayout>

        <!-- Row 4 -->
        <LinearLayout
            android:id="@+id/row4"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/r4_route"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="#F4F4F6"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/r4_dir"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="9sp"
                android:textColor="#9090B8"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/r4_eta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9090B8"
                android:layout_marginStart="8dp"
                android:minWidth="30dp"
                android:textAlignment="textEnd"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
