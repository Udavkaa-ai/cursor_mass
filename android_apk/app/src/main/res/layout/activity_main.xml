<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F10"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <!-- Заголовок: название остановки + кнопка настроек -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/tvStopName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="остановка"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"
            android:maxLines="1"
            android:ellipsize="end"/>

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Настройки"
            android:textSize="13sp"
            android:textColor="#7A7A80"
            android:background="@drawable/bg_card"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- Кнопка ЗАПУСТИТЬ / СТОП -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="12dp"
        android:text="ЗАПУСТИТЬ"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_btn"
        android:stateListAnimator="@null"/>

    <!-- Прогресс-бар времени сессии -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_marginTop="10dp"
        android:max="300"
        android:progress="0"
        android:progressDrawable="@drawable/progress_drawable"/>

    <!-- Строка статуса -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="нажми ЗАПУСТИТЬ"
            android:textSize="13sp"
            android:textColor="#7A7A80"/>

        <TextView
            android:id="@+id/tvNextPoll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#4382FF"/>
    </LinearLayout>

    <!-- Список прибытий -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

</LinearLayout>
