<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F10">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🚌 Автобусы"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"/>

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="+"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn"
            android:stateListAnimator="@null"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#1E1E21"/>

    <!-- Stops list (visible when non-empty) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone"/>

    <!-- Empty state onboarding (visible when no stops) -->
    <ScrollView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Как начать"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#F4F4F6"
                android:layout_marginBottom="16dp"/>

            <!-- Step 1 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="1"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_btn"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Откройте Яндекс Карты"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#F4F4F6"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Найдите свою остановку, нажмите «Поделиться» и скопируйте ссылку"
                        android:textSize="13sp" android:textColor="#7A7A80" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="2"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_btn"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Нажмите + и вставьте ссылку"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#F4F4F6"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="ID остановки определится автоматически. Нажмите «Загрузить» для имени"
                        android:textSize="13sp" android:textColor="#7A7A80" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="3"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_btn"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Фильтруйте маршруты (по желанию)"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#F4F4F6"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Введите номера через запятую: 925,907 — или оставьте пустым чтобы видеть все"
                        android:textSize="13sp" android:textColor="#7A7A80" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 4 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="4"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_btn"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Добавьте виджет на рабочий стол"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#F4F4F6"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Долгое нажатие на экран → Виджеты → Автобусы. Можно добавить несколько для разных остановок"
                        android:textSize="13sp" android:textColor="#7A7A80" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CTA button -->
            <Button
                android:id="@+id/btnAddEmpty"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:text="Добавить остановку"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
