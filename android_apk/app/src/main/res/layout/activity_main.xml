<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Dark blue header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1B3A6B"
        android:paddingStart="20dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ГДЕ АВТОБУС?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.06"/>

        <Button
            android:id="@+id/btnAdd"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="+"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"/>

    </LinearLayout>

    <!-- Content area with background image -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bg_main"
            android:scaleType="centerCrop"
            android:contentDescription="@null"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99000000"/>

    <!-- Stops list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"/>

    <!-- Empty state onboarding -->
    <ScrollView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Как начать"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="16dp"/>

            <!-- Step 1 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="1"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_route_badge"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Нажмите + и выберите остановку"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Нажмите «Выбрать на карте» и тапните на остановку. Или вставьте адрес из адресной строки браузера yandex.ru/maps"
                        android:textSize="13sp" android:textColor="#8A8A9A" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="2"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_route_badge"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Нажмите на остановку для отслеживания"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Нажмите ЗАПУСТИТЬ — автобусы обновляются каждые 15 секунд"
                        android:textSize="13sp" android:textColor="#8A8A9A" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="3"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_route_badge"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Фильтруйте маршруты (по желанию)"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Введите номера через запятую: 925,907 — или оставьте пустым чтобы видеть все"
                        android:textSize="13sp" android:textColor="#8A8A9A" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 4 -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="4"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_route_badge"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="2dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Добавьте виджет на рабочий стол"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Долгое нажатие на экран — Виджеты — Где автобус? Можно добавить несколько для разных остановок"
                        android:textSize="13sp" android:textColor="#8A8A9A" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CTA -->
            <Button
                android:id="@+id/btnAddEmpty"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:text="Добавить остановку"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </ScrollView>

    </FrameLayout>

</LinearLayout>
