<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#13100C">

    <!-- App bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1710"
        android:paddingStart="18dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="МОИ ОСТАНОВКИ"
                android:textSize="10sp"
                android:textColor="#9090B8"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Где автобус?"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="#F4F4F6"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnAdd"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Добавить"
            android:textSize="12sp"
            android:textColor="#6B9FD4"
            android:backgroundTint="#243555"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- Stops list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:visibility="gone"/>

    <!-- Empty state onboarding -->
    <ScrollView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Как начать"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#F4F4F6"
                android:layout_marginBottom="10dp"
                android:paddingStart="4dp"/>

            <!-- Step 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_stop_card"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="13dp"
                android:paddingBottom="13dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="1"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F4F4F6"
                    android:background="@drawable/bg_route_badge"
                    android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Нажмите «+ Добавить» и выберите остановку"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="#F4F4F6"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Нажмите «Выбрать на карте» и тапните на остановку"
                        android:textSize="11sp" android:textColor="#9090B8" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_stop_card"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="13dp"
                android:paddingBottom="13dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="2"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F4F4F6"
                    android:background="@drawable/bg_route_badge"
                    android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Нажмите на остановку, нажмите ЗАПУСТИТЬ"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="#F4F4F6"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Автобусы обновляются каждые 15 секунд"
                        android:textSize="11sp" android:textColor="#9090B8" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_stop_card"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="13dp"
                android:paddingBottom="13dp"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="3"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F4F4F6"
                    android:background="@drawable/bg_route_badge"
                    android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Фильтруйте маршруты (по желанию)"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="#F4F4F6"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Введите номера через запятую: 925,907 — или оставьте пустым"
                        android:textSize="11sp" android:textColor="#9090B8" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Step 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_stop_card"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="13dp"
                android:paddingBottom="13dp"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="4"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F4F4F6"
                    android:background="@drawable/bg_route_badge"
                    android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Добавьте виджет на рабочий стол"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="#F4F4F6"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Долгое нажатие на экран — Виджеты — Где автобус?"
                        android:textSize="11sp" android:textColor="#9090B8" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnAddEmpty"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Добавить остановку"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn"
                android:stateListAnimator="@null"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
