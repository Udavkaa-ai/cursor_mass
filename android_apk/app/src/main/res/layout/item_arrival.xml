<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_arrival_card"
    android:layout_marginBottom="9dp"
    android:baselineAligned="false">

    <!-- Colored accent strip — color set programmatically via vAccent.setBackgroundColor() -->
    <View
        android:id="@+id/vAccent"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#E53040"/>

    <!-- Left: route number + direction (58% width) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="58"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="12dp"
        android:paddingTop="13dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvType"
            android:layout_width="wrap_content"
            android:layout_height="16dp"
            android:layout_marginBottom="5dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:textColor="#F4F4F6"
            android:background="@drawable/bg_type_badge"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvRoute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#F4F4F6"
            android:letterSpacing="0.01"
            android:includeFontPadding="false"/>

        <TextView
            android:id="@+id/tvDirection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="11sp"
            android:textColor="#9090B8"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"/>

    </LinearLayout>

    <!-- Column divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#1A1916"/>

    <!-- Right: ETA number + unit (42% width) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="42"
        android:orientation="vertical"
        android:gravity="end|center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvEta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="46sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:textColor="#E53040"
            android:includeFontPadding="false"/>

        <TextView
            android:id="@+id/tvEtaUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="мин"
            android:textSize="11sp"
            android:fontFamily="sans-serif"
            android:textColor="#E53040"
            android:textAllCaps="true"
            android:letterSpacing="0.06"/>

    </LinearLayout>

</LinearLayout>
