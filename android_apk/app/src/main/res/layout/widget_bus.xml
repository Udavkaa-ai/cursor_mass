<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="8dp">

    <!-- Header: title + stop name + timer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Где автобус?"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#1B3A6B"
            android:letterSpacing="0.04"/>

        <TextView
            android:id="@+id/tw_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#1B3A6B"
            android:fontFamily="monospace"
            android:visibility="gone"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tw_stop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Остановка"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginBottom="4dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#D4D8E8"
        android:layout_marginBottom="4dp"/>

    <!-- IDLE: transparent tap area -->
    <TextView
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Нажмите для обновления"
        android:textSize="11sp"
        android:textColor="#9A9AB0"
        android:gravity="center"/>

    <!-- ACTIVE: arrival row 1 -->
    <LinearLayout
        android:id="@+id/row1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/r1_route"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="28dp"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_route_badge"
            android:layout_marginEnd="7dp"/>

        <TextView
            android:id="@+id/r1_dir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="9sp"
            android:textColor="#6A6A7A"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/r1_eta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FF7722"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <!-- ACTIVE: arrival row 2 -->
    <LinearLayout
        android:id="@+id/row2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/r2_route"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="28dp"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_route_badge"
            android:layout_marginEnd="7dp"/>

        <TextView
            android:id="@+id/r2_dir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="9sp"
            android:textColor="#6A6A7A"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/r2_eta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FF7722"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <!-- ACTIVE: arrival row 3 -->
    <LinearLayout
        android:id="@+id/row3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/r3_route"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="28dp"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_route_badge"
            android:layout_marginEnd="7dp"/>

        <TextView
            android:id="@+id/r3_dir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="9sp"
            android:textColor="#6A6A7A"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/r3_eta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FF7722"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <!-- Stop button: subtle text, no background -->
    <TextView
        android:id="@+id/btn_stop"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:layout_marginTop="2dp"
        android:text="Стоп"
        android:textSize="10sp"
        android:textColor="#9A9AB0"
        android:gravity="center"
        android:visibility="gone"/>

</LinearLayout>
