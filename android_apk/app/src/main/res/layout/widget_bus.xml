<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget"
    android:padding="10dp">

    <!-- Header: stop name + timer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tw_stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Остановка"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tw_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#4382FF"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Idle: Где автобус? -->
    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:text="Где автобус?"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_widget_btn"/>

    <!-- Active: arrival rows -->
    <LinearLayout
        android:id="@+id/row1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/r1_route"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"/>
        <TextView
            android:id="@+id/r1_eta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/r2_route"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"/>
        <TextView
            android:id="@+id/r2_eta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/r3_route"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"/>
        <TextView
            android:id="@+id/r3_eta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/r4_route"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"/>
        <TextView
            android:id="@+id/r4_eta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"/>
    </LinearLayout>

    <!-- Stop button (active state) -->
    <Button
        android:id="@+id/btn_stop"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_marginTop="4dp"
        android:text="Стоп"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_widget_btn_stop"
        android:visibility="gone"/>

</LinearLayout>
