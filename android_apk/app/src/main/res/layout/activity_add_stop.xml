<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F10"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Добавить остановку"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"
            android:layout_marginBottom="20dp"/>

        <!-- Yandex Maps URL paste -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ссылка из Яндекс.Карт"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="https://yandex.ru/maps/…/stops/…"
                android:textSize="14sp"
                android:textColor="#F4F4F6"
                android:textColorHint="#555570"
                android:background="@drawable/bg_card"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:inputType="textUri"
                android:singleLine="true"/>

            <Button
                android:id="@+id/btnParseUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="→ ID"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn"
                android:stateListAnimator="@null"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"/>
        </LinearLayout>

        <!-- Stop ID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ID остановки"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etStopId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="5854295457"
                android:textSize="16sp"
                android:textColor="#F4F4F6"
                android:textColorHint="#555570"
                android:background="@drawable/bg_card"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:inputType="number"
                android:singleLine="true"/>

            <Button
                android:id="@+id/btnFetchName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Загрузить"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_card"
                android:stateListAnimator="@null"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"/>
        </LinearLayout>

        <!-- Stop Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Название остановки"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etStopName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Авиамоторная, 1с1"
            android:textSize="16sp"
            android:textColor="#F4F4F6"
            android:textColorHint="#555570"
            android:background="@drawable/bg_card"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:singleLine="true"/>

        <!-- Routes -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фильтр маршрутов (необязательно)"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etRoutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="925,907  (пусто = все маршруты)"
            android:textSize="16sp"
            android:textColor="#F4F4F6"
            android:textColorHint="#555570"
            android:background="@drawable/bg_card"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:singleLine="true"/>

        <!-- Save -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="СОХРАНИТЬ"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>
