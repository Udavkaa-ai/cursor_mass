<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#13100C"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Добавить остановку"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#F4F4F6"
            android:layout_marginBottom="16dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPickMap"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:text="Выбрать на карте"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn"
            android:stateListAnimator="@null"/>

        <!-- Hidden stop ID used by code -->
        <EditText
            android:id="@+id/etStopId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Название остановки"
            android:textSize="12sp"
            android:textColor="#9090B8"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etStopName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="заполнится автоматически"
            android:textSize="15sp"
            android:textColor="#F4F4F6"
            android:textColorHint="#7878A0"
            android:background="@drawable/bg_card"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:singleLine="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Показывать только маршруты (необязательно)"
            android:textSize="12sp"
            android:textColor="#9090B8"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etRoutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="925,907 — через запятую, пусто = все"
            android:textSize="15sp"
            android:textColor="#F4F4F6"
            android:textColorHint="#7878A0"
            android:background="@drawable/bg_card"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:inputType="text"
            android:singleLine="true"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="СОХРАНИТЬ"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>
