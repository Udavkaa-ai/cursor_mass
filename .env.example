# Опциональная авторизация. Пусто = ручки доступны без X-API-Key (только для
# личного пользования и/или непубличного URL). Чтобы включить — поставь любую
# длинную случайную строку, например `openssl rand -hex 32`.
API_KEY=

# Список остановок прямо в env (рекомендуемый режим для Railway без volume).
# Если задан — сервис работает в read-only: список из этой переменной, POST/DELETE
# /stops отключены, БД не используется. Редактируй прямо в Railway → Variables.
# Если пусто — сервис идёт в SQLite (нужен volume для персистентности).
STOPS=[{"stop_id":"5854295457","name":"Улица Дорский Ручей","routes":["925"]}]

# Путь до SQLite-файла (используется только если STOPS не задана).
DATABASE_PATH=./data/db.sqlite3
