# Переменные окружения для деплоя в Y.Cloud Serverless Containers.
# Скопируй в env.yc и заполни своими значениями. Не коммить env.yc.
#
# Формат: KEY=value, по одной паре на строку.
# Внутри значения можно использовать кавычки и спецсимволы — без shell-экранирования.

STOPS=[{"stop_id":"5854295457","name":"Улица Дорский Ручей","routes":["925","907"]},{"stop_id":"5854297837","name":"Улица Красовского","routes":["925","907"]},{"stop_id":"9645038","name":"Рижская","routes":["714"]},{"stop_id":"9688802","name":"МЦД Щербинка","routes":["998","925"]}]

# Опционально: если задан, ручки требуют X-API-Key
# API_KEY=

# Опционально: ключ data.mos.ru — теперь рабочий, потому что русский IP
# MOS_API_KEY=954b65bffee1bd9811a2a8fb445b766f
